<!DOCTYPE html>
<html>
<head>
<title>Women Safety Analytics - Login</title>
<style>
body{
font-family:Arial;
background:#f4f4f4;
}

.container{
width:350px;
margin:100px auto;
background:white;
padding:20px;
border-radius:10px;
box-shadow:0 0 10px gray;
}

h2{
text-align:center;
color:#e91e63;
}

input{
width:100%;
padding:10px;
margin-bottom:15px;
}

button{
width:100%;
padding:10px;
background:#e91e63;
color:white;
border:none;
cursor:pointer;
}
</style>
</head>
<body>

<div class="container">

<h2>User Login</h2>

<input type="email" id="email"
placeholder="Enter Email">

<input type="password" id="password"
placeholder="Enter Password">

<button onclick="login()">
Login
</button>

<p>
New User?
<a href="register.html">
Register Here
</a>
</p>

</div>

<script src="auth.js"></script>

</body>
</html>
