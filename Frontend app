        body{
            margin:0;
            font-family:Arial;
            background:#f4f4f4;
        }

        /* Header */
        .header{
            background:#e91e63;
            color:white;
            padding:20px;
            text-align:center;
        }

        /* Sidebar */
        .sidebar{
            width:250px;
            height:100%;
            background:#222;
            position:fixed;
            left:0;
            top:0;
            padding-top:80px;
        }

        .sidebar a{
            display:block;
            color:white;
            padding:15px;
            text-decoration:none;
            font-size:18px;
        }

        .sidebar a:hover{
            background:#e91e63;
        }

        /* Main */
        .main{
            margin-left:270px;
            padding:20px;
        }

        /* Cards */
        .card{
            width:220px;
            background:white;
            display:inline-block;
            margin:15px;
            padding:20px;
            text-align:center;
            border-radius:10px;
            box-shadow:0px 0px 10px gray;
        }

        .card h2{
            color:#e91e63;
        }

        /* Tables */
        table{
            width:100%;
            border-collapse:collapse;
            background:white;
        }

        table,th,td{
            border:1px solid gray;
        }

        th{
            background:#e91e63;
            color:white;
            padding:10px;
        }

        td{
            padding:10px;
            text-align:center;
        }

        /* Buttons */
        button{
            background:#e91e63;
            color:white;
            border:none;
            padding:10px 20px;
            border-radius:5px;
        }

        button:hover{
            background:#c2185b;
        }

        /* Profile */
        .profile{
            background:white;
            padding:20px;
            border-radius:10px;
            box-shadow:0px 0px 10px gray;
        }

        .section{
            background:white;
            padding:20px;
            margin-top:20px;
            border-radius:10px;
            box-shadow:0px 0px 10px gray;
        }
    </style>
</head>

